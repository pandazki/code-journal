{
  "name": "@code-journal/tui",
  "version": "0.1.0",
  "private": true,
  "description": "code-journal TUI — discover, browse, and upload coding-agent sessions",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "check": "tsx src/cli.tsx --check",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'test/*.test.ts' 'test/*.test.tsx'",
    "build:binaries": "node scripts/build-binaries.mjs"
  },
  "engines": {
    "node": ">=20.18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@code-journal/core": "*",
    "ink": "^7.0.3",
    "react": "^19.2.6",
    "react-devtools-core": "^6.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0"
  }
}
