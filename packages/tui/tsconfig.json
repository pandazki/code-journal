{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2023"],
    "types": ["node", "react"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "composite": false
  },
  "include": ["src/**/*", "test/**/*"]
}
